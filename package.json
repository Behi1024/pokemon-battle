{
	"name": "auth-server",
	"main": "auth-server.ts",
	"type": "module",
	"scripts": {
		"dev": "tsx watch --conditions=development src/auth-server.ts",
		"build": "tsc",
		"start": "node dist/auth-server.js"
	},
	"imports": {
		"#db": {
			"development": "./src/config/db.ts",
			"default": "./dist/config/db.js"
		},
		"#models": {
			"development": "./src/models/modelsIndex.ts",
			"default": "./dist/models/modelsIndex.js"
		},
		"#types": {
			"development": "./src/types/typesIndex.ts",
			"default": "./dist/types/typesIndex.js"
		},
		"#controllers": {
			"development": "./src/controllers/controllersIndex.ts",
			"default": "./dist/controllers/controllersIndex.js"
		},
		"#routes": {
			"development": "./src/routes/routesIndex.ts",
			"default": "./dist/routes/routesIndex.js"
		},
		"#middleware": {
			"development": "./src/middleware/middlewareIndex.ts",
			"default": "./dist/middleware/middlewareIndex.js"
		}
	},
	"dependencies": {
		"bcrypt": "^6.0.0",
		"cors": "^2.8.6",
		"dotenv": "^17.4.2",
		"express": "^5.2.1",
		"jsonwebtoken": "^9.0.3",
		"mongoose": "^9.6.2",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/bcrypt": "^6.0.0",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^25.9.1",
		"tsx": "^4.22.3",
		"typescript": "^6.0.3"
	}
}
