{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",

		"rootDir": "./src",
		"outDir": "./dist",

		"strict": true,
		"skipLibCheck": true,

		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,

		"resolveJsonModule": true,
		"sourceMap": true,

		"declaration": true,

		"types": ["node"]

		//"customConditions": ["development"]
	},
	"include": ["src"]
}
